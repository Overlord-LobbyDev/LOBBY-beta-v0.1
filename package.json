{
  "name": "lobby",
  "version": "1.3.2",
  "description": "LOBBY \u2014 Your Gaming Social Hub",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.lobby.app",
    "productName": "LOBBY",
    "icon": "icon.ico",
    "win": {
      "icon": "icon.ico",
      "target": "nsis",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LOBBY",
      "deleteAppDataOnUninstall": false,
      "perMachine": false,
      "uninstallDisplayName": "LOBBY"
    }
  },
  "dependencies": {
    "express": "^5.2.1",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "electron": "^34.5.8",
    "electron-builder": "^26.8.1"
  },
  "engines": {
    "node": "18.x"
  }
}